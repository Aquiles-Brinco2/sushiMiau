@model (string Prefix, IReadOnlyList<SushiMiau.Shared.Contracts.OrderLine> Lines)

<div class="order-lines">
    <div class="line-grid order-line-grid line-grid-head"><span>Producto</span><span>Cant.</span><span>Precio</span><span>Total</span><span></span></div>
    @for (var index = 0; index < 5; index++)
    {
        var line = Model.Lines.ElementAtOrDefault(index);
        var item = index + 1;
        var quantity = line?.Quantity ?? (index == 0 ? 1 : 0);
        var price = line?.UnitPrice ?? 0;
        var total = quantity * price;
        <div class="line-grid order-line-grid" data-line-row>
            <input name="@($"{Model.Prefix}.Item{item}Name")" value="@line?.ItemName" list="menuItems" placeholder="Producto" required="@(index == 0 ? "required" : null)" />
            <input name="@($"{Model.Prefix}.Item{item}Quantity")" value="@quantity" type="number" min="0" placeholder="Cant." required="@(index == 0 ? "required" : null)" data-line-quantity />
            <input name="@($"{Model.Prefix}.Item{item}Price")" value="@price" type="number" step="0.01" placeholder="Precio" readonly required="@(index == 0 ? "required" : null)" data-line-price />
            <input value="@total.ToString("0.00")" type="number" step="0.01" placeholder="Total" readonly data-line-total />
            <button type="button" class="danger-button line-remove-button" data-clear-order-line>Quitar</button>
        </div>
    }
</div>
