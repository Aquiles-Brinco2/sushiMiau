@model SushiMiau.Web.Pages.PedidosModel

<div class="line-grid">
    <input asp-for="DeliveryOrder.Item1Name" list="menuItems" placeholder="Producto" required />
    <input asp-for="DeliveryOrder.Item1Quantity" type="number" min="1" placeholder="Cant." required />
    <input asp-for="DeliveryOrder.Item1Price" type="number" step="0.01" placeholder="Precio" required />
    <input asp-for="DeliveryOrder.Item2Name" list="menuItems" placeholder="Producto opcional" />
    <input asp-for="DeliveryOrder.Item2Quantity" type="number" min="0" placeholder="Cant." />
    <input asp-for="DeliveryOrder.Item2Price" type="number" step="0.01" placeholder="Precio" />
</div>
