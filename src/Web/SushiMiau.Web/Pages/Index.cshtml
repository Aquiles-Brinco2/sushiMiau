@page
@model IndexModel
@{
    ViewData["Title"] = "Panel";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Back office</p>
        <h1>Sushi Miau Gestion</h1>
        <p class="muted">Panel interno para administracion, operacion y control del restaurante.</p>
    </div>
    <div class="service-chip">Cassandra + microservicios .NET</div>
</section>

<section class="panel table-board-panel">
    <div class="panel-heading">
        <div>
            <h2>Panel de mesas</h2>
            <p>Estado operativo actual del salon.</p>
        </div>
    </div>
    <div class="table-board">
        <div class="table-grid">
            @foreach (var table in Model.Tables)
            {
                <button type="button" class="restaurant-table table-@CssStatus(table.Status)"
                        data-table-target="#table-detail-@Slug(table.TableName)">
                    <strong>@table.TableName</strong>
                    <span>@table.Status</span>
                    @if (table.Status == "Ocupada" && !string.IsNullOrWhiteSpace(table.OrderStatus))
                    {
                        <small>Pedido: @table.OrderStatus</small>
                    }
                </button>
            }
        </div>
        <div class="table-detail-stack">
            @foreach (var table in Model.Tables)
            {
                <article id="table-detail-@Slug(table.TableName)" class="table-detail" data-table-detail>
                    <header>
                        <span class="badge">@table.Status</span>
                        <h3>@table.TableName</h3>
                        <p class="muted">@table.Capacity personas</p>
                    </header>
                    <dl>
                        <div>
                            <dt>Empleado</dt>
                            <dd>@table.AssignedEmployee</dd>
                        </div>
                        <div>
                            <dt>Reserva</dt>
                            <dd>@ReservationText(table)</dd>
                        </div>
                        <div>
                            <dt>Pedidos</dt>
                            <dd>
                                @if (!table.PendingOrders.Any())
                                {
                                    <span>Sin pedido activo</span>
                                }
                                else
                                {
                                    <ul class="order-summary-list">
                                        @foreach (var pending in table.PendingOrders)
                                        {
                                            <li>
                                                <strong>@pending.Status</strong> - Bs @pending.Total.ToString("0.00")
                                                @if (!string.IsNullOrWhiteSpace(pending.CustomerName))
                                                {
                                                    <span class="muted">(@pending.CustomerName)</span>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            </dd>
                        </div>
                    </dl>
                    <div class="inline-actions">
                        <a class="secondary-button" asp-page="/Reservas" asp-route-table="@table.TableName">Hacer
                            reserva</a>
                            <a class="secondary-button" asp-page="/Pedidos" asp-route-table="@table.TableName">Hacer pedido</a>
                            @if (table.OrderId.HasValue)
                            {
                                <a class="secondary-button" asp-page="/Pedidos" asp-fragment="order-@table.OrderId">Detalle
                                    pedido</a>
                                }
                            </div>
                            <div class="inline-actions">
                                @if (table.Status == "Ocupada" || table.Status == "Reservada")
                                {
                                    <form method="post" asp-page-handler="TableState">
                                        <input type="hidden" asp-for="TableState.TableName" value="@table.TableName" />
                                        <input type="hidden" asp-for="TableState.Status" value="Disponible" />
                                        <input type="hidden" asp-for="TableState.OrderId" value="@table.OrderId" />
                                        <input type="hidden" asp-for="TableState.ReservationId" value="@table.ReservationId" />
                                        <button type="submit">Desocupar</button>
                                    </form>
                                }
                                else if (table.Status == "Fuera de servicio")
                                {
                                    <form method="post" asp-page-handler="TableState">
                                        <input type="hidden" asp-for="TableState.TableName" value="@table.TableName" />
                                        <input type="hidden" asp-for="TableState.Status" value="Disponible" />
                                        <button type="submit">Habilitar</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="TableState">
                                        <input type="hidden" asp-for="TableState.TableName" value="@table.TableName" />
                                        <input type="hidden" asp-for="TableState.Status" value="Ocupada" />
                                        <button type="submit">Ocupar</button>
                                    </form>
                                    <form method="post" asp-page-handler="TableState">
                                        <input type="hidden" asp-for="TableState.TableName" value="@table.TableName" />
                                        <input type="hidden" asp-for="TableState.Status" value="Fuera de servicio" />
                                        <button type="submit" class="secondary-button">Fuera de servicio</button>
                                    </form>
                                }
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>

@functions {
    private static string CssStatus(string status) => status switch
    {
        "Ocupada" => "occupied",
        "Reservada" => "reserved",
        "Fuera de servicio" => "offline",
        _ => "available"
    };

    private static string Slug(string value) => value.Replace(" ", "-",
StringComparison.OrdinalIgnoreCase).ToLowerInvariant();

    private static string ReservationText(TablePanelItem table)
    {
        if (table.ReservationStartsAt is null || table.ReservationEndsAt is null)
        {
            return "Sin reserva activa";
        }

        return $"{table.ReservationCustomer} ({table.ReservationPartySize} pers.) de {table.ReservationStartsAt.Value:HH:mm} a {table.ReservationEndsAt.Value:HH:mm}";
    }

    private static string OrderText(TablePanelItem table)
    {
        if (!table.PendingOrders.Any())
        {
            return "Sin pedido activo";
        }

        return string.Join(", ", table.PendingOrders.Select(order => $"{order.Status} - Bs {order.Total:0.00}"));
    }
}

<partial name="_Flash" model="(Model.Flash, Model.ErrorMessage)" />

<section class="metric-grid" aria-label="Resumen del dia">
    <article class="metric-card">
        <span>Ventas cobradas</span>
        <strong>Bs @Model.Dashboard.Sales.Total.ToString("0.00")</strong>
        <small>@Model.Dashboard.Sales.PaidOrders de @Model.Dashboard.Sales.Orders pedidos pagados</small>
    </article>
    <article class="metric-card">
        <span>Facturado</span>
        <strong>Bs @Model.Dashboard.Sales.InvoicedTotal.ToString("0.00")</strong>
        <small>Facturacion del dia</small>
    </article>
    <article class="metric-card">
        <span>Reservas</span>
        <strong>@Model.Dashboard.Reservations.Count</strong>
        <small>Agenda de hoy</small>
    </article>
    <article class="metric-card">
        <span>Alertas de stock</span>
        <strong>@Model.Dashboard.Inventory.LowStockItems</strong>
        <small>@Model.Dashboard.Inventory.TotalItems ingredientes controlados</small>
    </article>
</section>
