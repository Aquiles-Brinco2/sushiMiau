@page
@model ReservasModel
@{
    ViewData["Title"] = "Reservas";
}

<partial name="_Flash" model="(Model.Flash, Model.ErrorMessage)" />

<section class="module-heading">
    <div>
        <p class="eyebrow">Reservas</p>
        <h1>Agenda de mesas</h1>
        <p class="muted">Reservas internas con filtros y cliente registrado.</p>
    </div>
    <button type="button" data-dialog-open="#createReservation">Nueva reserva</button>
</section>

<section class="panel">
    <form method="get" class="toolbar">
        <input type="hidden" name="status" id="status-filter" value="@Model.FilterStatus" />
        <label>Fecha <input name="date" type="date" value="@Model.FilterDate" /></label>
        <label>Hora <input name="hour" type="time" value="@Model.FilterHour" /></label>
        <label>Cliente <input name="customer" list="customers" value="@Model.FilterCustomer" /></label>
        <button type="submit">Filtrar</button>
        <div class="toolbar-actions">
            <button type="submit" onclick="document.getElementById('status-filter').value = '';" class="secondary-button @(Model.ShowActiveReservations ? "active" : "")">Ver activas</button>
            <button type="submit" onclick="document.getElementById('status-filter').value = 'Completada';" class="secondary-button @(Model.ShowCompletedReservations ? "active" : "")">Ver completadas</button>
            <button type="submit" onclick="document.getElementById('status-filter').value = 'Cancelada';" class="secondary-button @(Model.ShowCancelledReservations ? "active" : "")">Ver canceladas</button>
        </div>
    </form>

    @if (Model.ShowActiveReservations)
    {
        <div class="panel-section">
            <h2>Pendientes</h2>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Mesa</th>
                            <th>Cliente</th>
                            <th>Personas</th>
                            <th>Estado</th>
                            <th>Notas</th>
                            <th>Accion</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reservation in Model.PendingReservations)
                        {
                            <tr>
                                <td>@reservation.BusinessDate</td>
                                <td>@reservation.ReservationTime.ToLocalTime().ToString("HH:mm")</td>
                                <td>@reservation.TableName</td>
                                <td><strong>@reservation.CustomerName</strong><br /><span
                                    class="muted">@reservation.CustomerPhone</span></td>
                                    <td>@reservation.PartySize</td>
                                    <td><span class="badge">@reservation.Status</span></td>
                                    <td>@reservation.Notes</td>
                                    <td>
                                        @if (Model.CanEditSelectedDate)
                                        {
                                            <form method="post" asp-page-handler="Status" class="inline-actions">
                                                <input type="hidden" asp-for="ReservationStatus.ReservationId"
                                                       value="@reservation.ReservationId" />
                                                <button name="ReservationStatus.Status" value="Confirmada"
                                                        type="submit">Confirmar</button>
                                                <button name="ReservationStatus.Status" value="Completada"
                                                        type="submit">Completar</button>
                                                <button name="ReservationStatus.Status" value="Cancelada"
                                                        type="submit">Cancelar</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge off">Ultimo estado: @reservation.Status</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="panel-section">
                <h2>Confirmadas</h2>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Mesa</th>
                                <th>Cliente</th>
                                <th>Personas</th>
                                <th>Estado</th>
                                <th>Notas</th>
                                <th>Accion</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reservation in Model.ConfirmedReservations)
                            {
                                <tr>
                                    <td>@reservation.BusinessDate</td>
                                    <td>@reservation.ReservationTime.ToLocalTime().ToString("HH:mm")</td>
                                    <td>@reservation.TableName</td>
                                    <td><strong>@reservation.CustomerName</strong><br /><span
                                        class="muted">@reservation.CustomerPhone</span></td>
                                        <td>@reservation.PartySize</td>
                                        <td><span class="badge ok">@reservation.Status</span></td>
                                        <td>@reservation.Notes</td>
                                        <td>
                                            @if (Model.CanEditSelectedDate)
                                            {
                                                <form method="post" asp-page-handler="Status" class="inline-actions">
                                                    <input type="hidden" asp-for="ReservationStatus.ReservationId"
                                                           value="@reservation.ReservationId" />
                                                    <button name="ReservationStatus.Status" value="Completada"
                                                            type="submit">Completar</button>
                                                    <button name="ReservationStatus.Status" value="Cancelada"
                                                            type="submit">Cancelar</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="badge off">Ultimo estado: @reservation.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
    else if (Model.ShowCompletedReservations)
            {
                <div class="panel-section">
                    <h2>Reservas completadas</h2>
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Hora</th>
                                    <th>Mesa</th>
                                    <th>Cliente</th>
                                    <th>Personas</th>
                                    <th>Estado</th>
                                    <th>Notas</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reservation in Model.CompletedReservations)
                                {
                                    <tr>
                                        <td>@reservation.BusinessDate</td>
                                        <td>@reservation.ReservationTime.ToLocalTime().ToString("HH:mm")</td>
                                        <td>@reservation.TableName</td>
                                        <td><strong>@reservation.CustomerName</strong><br /><span
                                            class="muted">@reservation.CustomerPhone</span></td>
                                            <td>@reservation.PartySize</td>
                                            <td><span class="badge ok">@reservation.Status</span></td>
                                            <td>@reservation.Notes</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
    else if (Model.ShowCancelledReservations)
                {
                    <div class="panel-section">
                        <h2>Reservas canceladas</h2>
                        <div class="table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Hora</th>
                                        <th>Mesa</th>
                                        <th>Cliente</th>
                                        <th>Personas</th>
                                        <th>Estado</th>
                                        <th>Notas</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var reservation in Model.CancelledReservations)
                                    {
                                        <tr class="status-cancelled">
                                            <td>@reservation.BusinessDate</td>
                                            <td>@reservation.ReservationTime.ToLocalTime().ToString("HH:mm")</td>
                                            <td>@reservation.TableName</td>
                                            <td><strong>@reservation.CustomerName</strong><br /><span
                                                class="muted">@reservation.CustomerPhone</span></td>
                                                <td>@reservation.PartySize</td>
                                                <td><span class="badge alert-badge">@reservation.Status</span></td>
                                                <td>@reservation.Notes</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </section>

                <dialog id="createReservation">
                    <div class="dialog-head">
                        <h2>Nueva reserva</h2><button type="button" data-dialog-close>x</button>
                    </div>
                    <form method="post" asp-page-handler="Create" class="dialog-body form-box">
                        <label>Cliente
                            <select asp-for="Reservation.CustomerId" required>
                                <option value="">Seleccionar cliente</option>
                                @foreach (var customer in Model.Customers)
                                {
                                    <option value="@customer.CustomerId">@customer.Name -
                                        @customer.Phone</option>
                                    }
                                </select>
                            </label>
                            <button type="button" class="secondary-button" data-dialog-open="#createCustomer">Registrar cliente</button>
                            <label>Mesa
                                <select asp-for="Reservation.TableName" required data-table-capacity-select>
                                    <option value="">Seleccionar mesa</option>
                                    @foreach (var table in Model.Tables)
                                    {
                                        <option value="@table.TableName" data-capacity="@table.Capacity">@table.TableName (@table.Capacity
                                            personas)</option>
                                        }
                                    </select>
                                </label>
                                <label>Personas
                                    <input asp-for="Reservation.PartySize" type="number" min="1" required data-party-size />
                                    <small class="muted" data-capacity-help>Seleccione una mesa para ver su capacidad.</small>
                                </label>
                                <label>Fecha y hora <input asp-for="Reservation.ReservationTime" type="datetime-local" required /></label>
                                <label>Notas <span class="muted">(opcional)</span><textarea asp-for="Reservation.Notes"
                                                                                                rows="3"></textarea></label>
                                    <h3>Pedido opcional</h3>
                                    <label>Operador <input value="@(User.Identity?.Name ?? "Operador")" disabled /></label>
                                    <partial name="_OptionalOrderLines" model='(Prefix: "OptionalOrder", Menu: Model.Menu)' />
                                    <button type="submit">Registrar reserva</button>
                                </form>
                            </dialog>

                            <dialog id="createCustomer">
                                <div class="dialog-head">
                                    <h2>Registrar cliente</h2><button type="button" data-dialog-close>x</button>
                                </div>
                                <form method="post" asp-page-handler="Customer" class="dialog-body form-box">
                                    <label>Nombre <input asp-for="Customer.Name" required /></label>
                                    <label>Telefono <input asp-for="Customer.Phone" required /></label>
                                    <label>NIT/CI <input asp-for="Customer.Nit" required /></label>
                                    <button type="submit">Guardar cliente</button>
                                </form>
                            </dialog>

                            <datalist id="customers">
                                @foreach (var customer in Model.Customers)
                                {
                                    <option value="@customer.Name"></option>
                                }
                            </datalist>