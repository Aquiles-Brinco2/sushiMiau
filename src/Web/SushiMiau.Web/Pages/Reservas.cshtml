@page
@model ReservasModel
@{
    ViewData["Title"] = "Reservas";
}

<partial name="_Flash" model="(Model.Flash, Model.ErrorMessage)" />

<section class="module-heading">
    <div>
        <p class="eyebrow">Reservas</p>
        <h1>Agenda de mesas</h1>
        <p class="muted">Reservas internas con filtros y cliente registrado.</p>
    </div>
    <button type="button" data-dialog-open="#createReservation">Nueva reserva</button>
</section>

<section class="panel">
    <form method="get" class="toolbar">
        <label>Fecha <input name="date" type="date" value="@Model.FilterDate" /></label>
        <label>Estado <input name="status" list="reservationStatuses" value="@Model.FilterStatus" /></label>
        <label>Hora <input name="hour" type="time" value="@Model.FilterHour" /></label>
        <label>Cliente <input name="customer" list="customers" value="@Model.FilterCustomer" /></label>
        <button type="submit">Filtrar</button>
    </form>
    <div class="table-wrap">
        <table>
            <thead><tr><th>Fecha</th><th>Hora</th><th>Cliente</th><th>Personas</th><th>Estado</th><th>Notas</th><th>Accion</th></tr></thead>
            <tbody>
            @foreach (var reservation in Model.Reservations)
            {
                <tr class="@(reservation.Status == "Cancelada" ? "status-cancelled" : "")">
                    <td>@reservation.BusinessDate</td>
                    <td>@reservation.ReservationTime.ToLocalTime().ToString("HH:mm")</td>
                    <td><strong>@reservation.CustomerName</strong><br /><span class="muted">@reservation.CustomerPhone</span></td>
                    <td>@reservation.PartySize</td>
                    <td><span class="badge @(reservation.Status == "Cancelada" ? "alert-badge" : "ok")">@reservation.Status</span></td>
                    <td>@reservation.Notes</td>
                    <td>
                        <form method="post" asp-page-handler="Status" class="inline-actions">
                            <input type="hidden" asp-for="ReservationStatus.ReservationId" value="@reservation.ReservationId" />
                            <button name="ReservationStatus.Status" value="Confirmada" type="submit">Confirmar</button>
                            <button name="ReservationStatus.Status" value="Completada" type="submit">Completar</button>
                            <button name="ReservationStatus.Status" value="Cancelada" type="submit">Cancelar</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

<dialog id="createReservation">
    <div class="dialog-head"><h2>Nueva reserva</h2><button type="button" data-dialog-close>x</button></div>
    <form method="post" asp-page-handler="Create" class="dialog-body form-box">
        <label>Cliente <input asp-for="Reservation.CustomerName" list="customers" required /></label>
        <button type="button" class="secondary-button" data-dialog-open="#createCustomer">Registrar cliente</button>
        <label>Telefono <input asp-for="Reservation.CustomerPhone" required /></label>
        <label>Personas <input asp-for="Reservation.PartySize" type="number" min="1" required /></label>
        <label>Fecha y hora <input asp-for="Reservation.ReservationTime" type="datetime-local" required /></label>
        <label>Notas <textarea asp-for="Reservation.Notes" rows="3"></textarea></label>
        <h3>Pedido opcional</h3>
        <label>Operador <input asp-for="OptionalOrder.ServerName" /></label>
        <div class="line-grid">
            <input asp-for="OptionalOrder.Item1Name" list="menuItems" placeholder="Producto opcional" />
            <input asp-for="OptionalOrder.Item1Quantity" type="number" min="0" placeholder="Cant." />
            <input asp-for="OptionalOrder.Item1Price" type="number" step="0.01" placeholder="Precio" />
            <input asp-for="OptionalOrder.Item2Name" list="menuItems" placeholder="Producto opcional" />
            <input asp-for="OptionalOrder.Item2Quantity" type="number" min="0" placeholder="Cant." />
            <input asp-for="OptionalOrder.Item2Price" type="number" step="0.01" placeholder="Precio" />
        </div>
        <button type="submit">Registrar reserva</button>
    </form>
</dialog>

<dialog id="createCustomer">
    <div class="dialog-head"><h2>Registrar cliente</h2><button type="button" data-dialog-close>x</button></div>
    <form method="post" asp-page-handler="Customer" class="dialog-body form-box">
        <label>Nombre <input asp-for="Customer.Name" required /></label>
        <label>Telefono <input asp-for="Customer.Phone" required /></label>
        <label>NIT/CI <input asp-for="Customer.Nit" required /></label>
        <button type="submit">Guardar cliente</button>
    </form>
</dialog>

<datalist id="customers">
    @foreach (var customer in Model.Customers)
    {
        <option value="@customer.Name"></option>
    }
</datalist>
<datalist id="reservationStatuses"><option value="Pendiente"></option><option value="Confirmada"></option><option value="Completada"></option><option value="Cancelada"></option></datalist>
<datalist id="menuItems">
    @foreach (var item in Model.Menu)
    {
        <option value="@item.Name"></option>
    }
</datalist>
