@page
@model ProveedoresModel
@{
    ViewData["Title"] = "Proveedores";
}

<partial name="_Flash" model="(Model.Flash, Model.ErrorMessage)" />

<section class="module-heading">
    <div>
        <p class="eyebrow">Abastecimiento</p>
        <h1>Proveedores y compras</h1>
        <p class="muted">Ordenes de insumos con cantidades, precios y recepcion en inventario.</p>
    </div>
    <div class="inline-actions">
        <button type="button" class="secondary-button" data-dialog-open="#createSupplier">Nuevo proveedor</button>
        <button type="button" data-dialog-open="#createPurchaseOrder">Nueva orden</button>
    </div>
</section>

<section class="workspace-grid">
    <div class="panel">
        <div class="panel-heading"><h2>Proveedores</h2></div>
        <div class="table-wrap">
            <table>
                <thead><tr><th>Proveedor</th><th>Contacto</th><th>Estado</th><th>Acciones</th></tr></thead>
                <tbody>
                @foreach (var supplier in Model.Suppliers)
                {
                    <tr>
                        <td><strong>@supplier.Name</strong><br /><small>@supplier.Email</small></td>
                        <td>@supplier.ContactName<br /><small>@supplier.Phone</small></td>
                        <td><span class="badge @(supplier.IsActive ? "ok" : "off")">@(supplier.IsActive ? "Activo" : "Inactivo")</span></td>
                        <td class="inline-actions">
                            <button type="button" class="secondary-button" data-dialog-open="#edit-supplier-@supplier.SupplierId">Editar</button>
                            <form method="post" asp-page-handler="DeleteSupplier" data-confirm="Esta seguro?">
                                <input type="hidden" asp-for="Delete.Id" value="@supplier.SupplierId" />
                                <button type="submit" class="danger-button">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="panel wide">
        <div class="panel-heading"><h2>Ordenes de compra</h2></div>
        <div class="table-wrap">
            <table>
                <thead><tr><th>Orden</th><th>Proveedor</th><th>Detalle</th><th>Total</th><th>Estado</th><th>Acciones</th></tr></thead>
                <tbody>
                @foreach (var order in Model.PurchaseOrders)
                {
                    <tr>
                        <td><strong>@order.OrderNumber</strong><br /><small>@order.OrderedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small></td>
                        <td>@order.SupplierName</td>
                        <td>@string.Join(", ", order.Lines.Select(line => $"{line.Quantity:0.##} {line.Unit} {line.IngredientName} x Bs {line.UnitPrice:0.00}"))</td>
                        <td>Bs @order.Total.ToString("0.00")</td>
                        <td><span class="badge">@order.Status</span></td>
                        <td class="inline-actions">
                            @if (order.Status != "Recibida" && order.Status != "Cancelada")
                            {
                                <form method="post" asp-page-handler="OrderStatus">
                                    <input type="hidden" name="purchaseOrderId" value="@order.PurchaseOrderId" />
                                    <button name="status" value="Recibida" type="submit">Recibir</button>
                                    <button name="status" value="Cancelada" type="submit" class="secondary-button">Cancelar</button>
                                </form>
                            }
                            <form method="post" asp-page-handler="DeleteOrder" data-confirm="Esta seguro?">
                                <input type="hidden" asp-for="Delete.Id" value="@order.PurchaseOrderId" />
                                <button type="submit" class="danger-button">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</section>

<dialog id="createSupplier">
    <div class="dialog-head"><h2>Nuevo proveedor</h2><button type="button" data-dialog-close>x</button></div>
    <form method="post" asp-page-handler="CreateSupplier" class="dialog-body form-box">
        <label>Nombre <input asp-for="Supplier.Name" required /></label>
        <label>Contacto <input asp-for="Supplier.ContactName" required /></label>
        <label>Telefono <input asp-for="Supplier.Phone" required /></label>
        <label>Correo <input asp-for="Supplier.Email" type="email" /></label>
        <label>Direccion <textarea asp-for="Supplier.Address"></textarea></label>
        <label class="check-line"><input asp-for="Supplier.IsActive" /> Activo</label>
        <button type="submit">Guardar proveedor</button>
    </form>
</dialog>

@foreach (var supplier in Model.Suppliers)
{
    <dialog id="edit-supplier-@supplier.SupplierId">
        <div class="dialog-head"><h2>Editar proveedor</h2><button type="button" data-dialog-close>x</button></div>
        <form method="post" asp-page-handler="UpdateSupplier" class="dialog-body form-box">
            <input type="hidden" asp-for="Supplier.SupplierId" value="@supplier.SupplierId" />
            <label>Nombre <input asp-for="Supplier.Name" value="@supplier.Name" required /></label>
            <label>Contacto <input asp-for="Supplier.ContactName" value="@supplier.ContactName" required /></label>
            <label>Telefono <input asp-for="Supplier.Phone" value="@supplier.Phone" required /></label>
            <label>Correo <input asp-for="Supplier.Email" type="email" value="@supplier.Email" /></label>
            <label>Direccion <textarea asp-for="Supplier.Address">@supplier.Address</textarea></label>
            <label class="check-line"><input asp-for="Supplier.IsActive" checked="@supplier.IsActive" /> Activo</label>
            <button type="submit">Guardar cambios</button>
        </form>
    </dialog>
}

<dialog id="createPurchaseOrder">
    <div class="dialog-head"><h2>Nueva orden de compra</h2><button type="button" data-dialog-close>x</button></div>
    <form method="post" asp-page-handler="CreateOrder" class="dialog-body form-box" data-purchase-form>
        <label>Proveedor
            <select asp-for="PurchaseOrder.SupplierId" required>
                <option value="">Seleccionar</option>
                @foreach (var supplier in Model.Suppliers.Where(item => item.IsActive)) { <option value="@supplier.SupplierId">@supplier.Name</option> }
            </select>
        </label>
        <div data-purchase-lines>
            <div class="line-grid" data-purchase-line>
                <select name="PurchaseOrder.Lines[0].InventoryItemId" required>
                    <option value="">Ingrediente</option>
                    @foreach (var item in Model.InventoryItems) { <option value="@item.ItemId">@item.Name (@item.Unit)</option> }
                </select>
                <input name="PurchaseOrder.Lines[0].Quantity" type="number" min="0.01" step="0.01" value="1" placeholder="Cantidad" required />
                <input name="PurchaseOrder.Lines[0].UnitPrice" type="number" min="0" step="0.01" placeholder="Precio unitario" required />
            </div>
            <template data-purchase-template>
                <div class="line-grid" data-purchase-line>
                    <select required>
                        <option value="">Ingrediente</option>
                        @foreach (var item in Model.InventoryItems) { <option value="@item.ItemId">@item.Name (@item.Unit)</option> }
                    </select>
                    <input type="number" min="0.01" step="0.01" value="1" placeholder="Cantidad" required />
                    <input type="number" min="0" step="0.01" placeholder="Precio unitario" required />
                </div>
            </template>
            <button type="button" class="secondary-button" data-add-purchase-line>Agregar ingrediente</button>
        </div>
        <label>Notas <textarea asp-for="PurchaseOrder.Notes"></textarea></label>
        <button type="submit">Registrar orden</button>
    </form>
</dialog>
