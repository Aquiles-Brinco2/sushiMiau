@page
@model ClientesModel
@{
    ViewData["Title"] = "Clientes";
}

<partial name="_Flash" model="(Model.Flash, Model.ErrorMessage)" />

<section class="module-heading">
    <div>
        <p class="eyebrow">Clientes</p>
        <h1>Clientes registrados</h1>
        <p class="muted">Datos mínimos para reservas, pedidos y facturación.</p>
    </div>
    <button type="button" data-dialog-open="#createCustomer">Registrar cliente</button>
</section>

<section class="panel">
    <div class="table-wrap">
        <table>
            <thead><tr><th>Nombre</th><th>Telefono</th><th>NIT/CI</th><th>Creado</th><th>Acciones</th></tr></thead>
            <tbody>
            @foreach (var customer in Model.Customers)
            {
                <tr>
                    <td><strong>@customer.Name</strong></td>
                    <td>@customer.Phone</td>
                    <td>@customer.Nit</td>
                    <td>@customer.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td class="inline-actions">
                        <button type="button" class="secondary-button" data-dialog-open="#edit-customer-@customer.CustomerId">Editar</button>
                        <form method="post" asp-page-handler="Delete" data-confirm="Esta seguro?">
                            <input type="hidden" asp-for="Delete.Id" value="@customer.CustomerId" />
                            <button type="submit" class="danger-button">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

<dialog id="createCustomer">
    <div class="dialog-head"><h2>Registrar cliente</h2><button type="button" data-dialog-close>×</button></div>
    <form method="post" asp-page-handler="Create" class="dialog-body form-box">
        <label>Nombre <input asp-for="Customer.Name" required /></label>
        <label>Telefono <input asp-for="Customer.Phone" required /></label>
        <label>NIT/CI <input asp-for="Customer.Nit" required /></label>
        <button type="submit">Guardar cliente</button>
    </form>
</dialog>

@foreach (var customer in Model.Customers)
{
    <dialog id="edit-customer-@customer.CustomerId">
        <div class="dialog-head"><h2>Editar cliente</h2><button type="button" data-dialog-close>x</button></div>
        <form method="post" asp-page-handler="Update" class="dialog-body form-box">
            <input type="hidden" asp-for="Customer.CustomerId" value="@customer.CustomerId" />
            <label>Nombre <input asp-for="Customer.Name" value="@customer.Name" required /></label>
            <label>Telefono <input asp-for="Customer.Phone" value="@customer.Phone" required /></label>
            <label>NIT/CI <input asp-for="Customer.Nit" value="@customer.Nit" required /></label>
            <button type="submit">Guardar cambios</button>
        </form>
    </dialog>
}
